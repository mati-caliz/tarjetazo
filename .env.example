# Casilla de Gmail donde caen los resúmenes de BNA (se leen por IMAP).
# EMAIL_USER = la dirección de Gmail
# EMAIL_APP_PASSWORD = app password de Gmail (requiere verificación en 2 pasos activada)
EMAIL_USER=
EMAIL_APP_PASSWORD=

# Opcional: host IMAP. Por defecto imap.gmail.com.
# IMAP_HOST=imap.gmail.com

# Clave del PDF del resumen BNA (tu DNI)
PDF_PASSWORD=

# Bot de Telegram (de @BotFather) y el chat_id donde te llega el resumen
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Opcional: si está seteada, se usa Claude para categorizar comercios
# que no matchean ninguna regla. Si no está, esos van a "Otros".
ANTHROPIC_API_KEY=
